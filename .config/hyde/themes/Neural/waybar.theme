$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh

/* Neural — electric violet and data cyan on deep purple-black */
@define-color bar-bg rgba(7, 5, 15, 0.85);

@define-color main-bg #100B1C;
@define-color main-fg #E8E0FF;

@define-color wb-act-bg #7B61FF;
@define-color wb-act-fg #07050F;

@define-color wb-hvr-bg #00D9FF;
@define-color wb-hvr-fg #07050F;
