$HOME/.config/waybar/theme.css|${scrDir}/wbarconfgen.sh

/* Claude Dark — warm coral-orange on near-black */
@define-color bar-bg rgba(26, 17, 16, 0.85);

@define-color main-bg #262120;
@define-color main-fg #F0EBE3;

@define-color wb-act-bg #D97757;
@define-color wb-act-fg #1A1110;

@define-color wb-hvr-bg #A85C3A;
@define-color wb-hvr-fg #F0EBE3;
